{
    // 咸鱼之王 —— 每日任务「进行3次点金」
    // 流程：每日任务页 -> 点"进行3次点金"行的"前往" -> 每日点金页 ->
    //       循环3次[点"点金一次" -> 弹"恭喜获得" -> 点空白关] -> 完成
    // 坐标基于 720 缩放系，box 来自实测 OCR。前置：游戏在每日任务页。

    // 入口：确认在每日任务页，去点"点金"的前往
    "点金_入口": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            10,
            420,
            360,
            160
        ],
        "action": "DoNothing",
        "post_delay": 300,
        "timeout": 4000,
        // 第二条兜底：今日该任务已完成、行不在可视列表时，"点前往"OCR 不命中，
        // 当轮落到"点金_完成"(DoNothing)立即跳过，串联跑不卡。
        "next": [
            "点金_点前往",
            "点金_完成"
        ]
    },

    // 用"进行...点金"文字定位任务行，target_offset 右移到该行"前往"。
    // 实测：文字 box≈[157,900,128,28]（中心x≈221），前往中心x≈588，x 偏移≈+367。
    "点金_点前往": {
        "recognition": "OCR",
        "expected": "进行.*次点金",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            367,
            0,
            0,
            0
        ],
        "post_delay": 2500,
        // 已完成时点到"已领"章无效、进不了活动页，下一活动节点识别不到 ->
        // 5s 内轮询落到"_完成"跳过，串联跑不卡。
        "timeout": 5000,
        "next": [
            "点金_第1次",
            "点金_完成"
        ]
    },

    // 点金页"点金一次"按钮 box≈[268,976,180,56]，中心[358,1004]。
    // 任务需点金3次，固定点3次（每次点完弹"恭喜获得"，点空白关）。
    // 每"点金_第N次"节点：识别"点金一次"按钮并点击 -> 关结果 -> 下一次。
    "点金_第1次": {
        "recognition": "OCR",
        "expected": "点金一次",
        "roi": [
            240,
            950,
            240,
            110
        ],
        "action": "Click",
        "post_delay": 2200,
        "next": [
            "点金_关结果1"
        ]
    },
    "点金_关结果1": {
        "action": "Click",
        "target": [
            360,
            250,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "点金_第2次"
        ]
    },

    "点金_第2次": {
        "recognition": "OCR",
        "expected": "点金一次",
        "roi": [
            240,
