            110
        ],
        "action": "Click",
        "post_delay": 2200,
        "next": [
            "点金_关结果3"
        ]
    },
    "点金_关结果3": {
        "action": "Click",
        "target": [
            360,
            250,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "点金_返回任务列表"
        ]
    },

    // 点金做完停在每日点金页，点左下返回箭头回任务列表。720系约[48,1152]。
    "点金_返回任务列表": {
        "action": "Click",
        "target": [
            48,
