{
    // 咸鱼之王 —— 收邮件 + 领福利活动(充值菜单)各 tab 奖励
    // 两条独立流程，各自从主界面起跑，可分别在 interface.json 配成 GUI task；
    // 邮件_完成 串接 充值_启动，故跑 邮件_启动 = 收邮件 + 领福利一条龙。
    //
    // 共同套路（实测自模拟器2，900x1600 物理 / short_side=720）：
    //   主界面点左上任务图标弹左侧菜单 -> OCR 点菜单项进对应页 -> OCR 领取按钮循环领
    //   -> 领完按钮变样(识别不到) -> 落到点左下返回箭头退出。
    // 关键：领取按钮/标签位置会浮动或滚动，一律 OCR 识别点 box(target:true)，不用固定坐标。
    // 坐标基于 720 缩放系。任务图标坐标与 xyzw_alldaily.json 的 全日常_开任务页 一致 [70,150]。
    // 返回箭头 [48,1152] 同各任务子页（物理[60,1440]）。

    // ===================== 收邮件 =====================
    // 入口：主界面。点左上任务图标弹左侧菜单；菜单没弹出(OCR没识别到"邮件")就再点一次，受 timeout 兜底。
    "邮件_启动": {
        "action": "Click",
        "target": [
            70,
            150,
            40,
            40
        ],
        "post_delay": 1800,
        "timeout": 30000,
        "next": [
            "邮件_点菜单",
            "邮件_启动"
        ]
    },
    // 左侧菜单点"邮件"项进邮件系统页。roi 限定左侧菜单"邮件"那一格(招募在上、任务在下，避开)。
    "邮件_点菜单": {
        "recognition": "OCR",
        "expected": "邮件",
        "roi": [
            20,
            370,
            210,
            150
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1800,
        "next": [
            "邮件_一键领取",
            "邮件_返回"
        ]
    },
    // 邮件页底部"一键领取"(有未读时为黄色按钮)。OCR 识别点 box；领完按钮变绿色"一键已读"，
    // 此节点识别不到"一键领取" -> next 落到 邮件_返回 退出。
    "邮件_一键领取": {
        "recognition": "OCR",
        "expected": "一键领取",
        "roi": [
            260,
            930,
            460,
            200
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1800,
        "next": [
            "邮件_关奖励"
        ]
    },
    // 领取后弹"恭喜获得"奖励窗，点空白关掉，再回去找"一键领取"(领完则识别不到 -> 返回)。
    "邮件_关奖励": {
        "action": "Click",
        "target": [
            360,
            200,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "邮件_一键领取",
            "邮件_返回"
        ]
    },
    // 无可领(识别不到一键领取) -> 点左下返回箭头退出邮件页。
    "邮件_返回": {
        "action": "Click",
        "target": [
            48,
            1152,
            1,
            1
        ],
        "post_delay": 1800,
        "next": [
            "邮件_完成"
        ]
    },
    // 邮件收完接着去领福利(充值)。邮件返回后停在主界面菜单展开态，
    // 充值_启动 点任务图标会收/重弹菜单，靠其自身 timeout 重试自愈到福利页。
    "邮件_完成": {
        "action": "DoNothing",
        "next": [
            "充值_启动"
        ]
    },

    // ============ 领福利活动(充值菜单进)：签到 + 每日特惠 + 尊享福利卡 ============
    // "充值"菜单进的是「福利活动」页，默认"签到"标签。顶部标签栏：签到/每日特惠/积天好礼/基金商城/尊享。
    // 本流程依次领三个免费项：签到"一键领取" -> 每日特惠"免费礼包" -> 尊享特权下二级"福利卡"的"领取"。
    // (积天好礼/基金商城/付费卡 不碰；付费按钮是"¥xx购买"，OCR 领取关键词不会误匹配。)
    // 领取后点空白关"恭喜获得"会留在当前 tab(不退页)，故可连续切 tab。
    // 切 tab 必须用 OCR(标签栏随选中滚动，固定坐标会偏)；领取按钮也 OCR 点 box，领完变样识别不到则进下一步。
    "充值_启动": {
        "action": "Click",
        "target": [
            70,
            150,
            40,
            40
        ],
        "post_delay": 1800,
        "timeout": 30000,
        "next": [
            "充值_点菜单",
            "充值_启动"
        ]
    },
    // 左侧菜单点"充值"项进福利活动页(排行在上、好友在下，roi 避开)。
    // post_delay 2500 让福利页加载完(签到/每日特惠标签固定)，进 next 循环时切特惠 OCR 第一轮即命中，
    // 兜底 充值_返回 不会被抢跑；同时保留它，万一没进福利页(异常)能返回不卡死。
    "充值_点菜单": {
        "recognition": "OCR",
        "expected": "充值",
        "roi": [
            20,
            780,
            210,
            150
        ],
        "action": "Click",
        "target": true,
        "post_delay": 2500,
        "next": [
            "充值_签到领取",
            "充值_切特惠",
            "充值_返回"
        ]
    },

    // ---- 签到 tab(进福利页默认) ----
    // 底部"一键领取"(位置随签到进度浮动，OCR 点 box)。领完变"一键已读"识别不到 -> 切每日特惠。
    "充值_签到领取": {
        "recognition": "OCR",
        "expected": "一键领取",
        "roi": [
            260,
            930,
            460,
            200
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1800,
        "next": [
            "充值_签到关弹窗"
        ]
    },
    "充值_签到关弹窗": {
        "action": "Click",
        "target": [
            360,
            200,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "充值_签到领取",
            "充值_切特惠"
        ]
    },

    // ---- 每日特惠 tab ----
    // OCR 点顶部"每日特惠"标签切过去(标签栏 y≈360)。
    "充值_切特惠": {
        "recognition": "OCR",
        "expected": "每日特惠",
        "roi": [
            180,
            330,
            200,
            70
        ],
        "action": "Click",
        "target": true,
        "post_delay": 2500,
        "next": [
            "充值_特惠领取",
            "充值_滑标签",
            "充值_返回"
        ]
    },
    // 右上绿色"免费礼包"按钮(付费礼包是"¥xx"，不匹配)。领完变灰识别不到 -> 切尊享。
    "充值_特惠领取": {
        "recognition": "OCR",
        "expected": "免费礼包",
        "roi": [
            480,
            540,
            200,
            80
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1800,
        "next": [
            "充值_特惠关弹窗"
        ]
    },
    "充值_特惠关弹窗": {
        "action": "Click",
        "target": [
            360,
            200,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "充值_滑标签"
        ]
    },

    // ---- 尊享特权 tab -> 福利卡(免费每日领) ----
    // 坑：每日特惠 tab 下标签栏自动滚到左侧，"尊享特权"被挤到最右边缘只露"尊享"二字，
    // 直接 OCR"尊享"点 box 会点偏到相邻的"基金商城"。故先把标签栏向左滑一段，
    // 让"尊享特权"完整滚入中部(实测滑 300px 后 box≈[280,349,89,24] 中心[325,361])，再精准 OCR 全称。
    "充值_滑标签": {
        "action": "Swipe",
        "begin": [
            600,
            361
        ],
        "end": [
            300,
            361
        ],
        "duration": 500,
        "post_delay": 1500,
        "next": [
            "充值_切尊享"
        ]
    },
    // 滑动后 OCR 全称"尊享特权"(滑后居中、不在边缘)，roi 收到中部 x150~510 防误匹配其它标签。
    "充值_切尊享": {
        "recognition": "OCR",
        "expected": "尊享特权",
        "roi": [
            150,
            330,
            360,
            70
        ],
        "action": "Click",
        "target": true,
        "post_delay": 2500,
        "next": [
            "充值_切福利卡",
            "充值_返回"
        ]
    },
    // 尊享下二级标签(终身卡/月卡/周卡/福利卡，y≈440)，点"福利卡"(唯一免费)。roi 放宽整条二级栏。
    // post_delay 给足让福利卡页加载完，使下一节点"领取"OCR 第一轮即可判定(领/已领)。
    "充值_切福利卡": {
        "recognition": "OCR",
        "expected": "福利卡",
        "roi": [
            0,
            410,
            720,
            70
        ],
        "action": "Click",
        "target": true,
        "post_delay": 2500,
        "next": [
            "充值_福利卡领取",
            "充值_返回"
        ]
    },
    // 福利卡底部绿色"领取"按钮(每日金砖)。领完变"已领取"，^领取$ 不匹配 -> 返回。
    "充值_福利卡领取": {
        "recognition": "OCR",
        "expected": "^领取$",
        "roi": [
            260,
            1010,
            200,
            90
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1800,
        "next": [
            "充值_福利卡关弹窗",
            "充值_返回"
        ]
    },
    "充值_福利卡关弹窗": {
        "action": "Click",
        "target": [
            360,
            200,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "充值_返回"
        ]
    },

    // 全部领完 -> 点左下返回箭头退出福利页。
    "充值_返回": {
        "action": "Click",
        "target": [
            48,
            1152,
            1,
            1
        ],
        "post_delay": 1800,
        "next": [
            "充值_完成"
        ]
    },
    "充值_完成": {
        "action": "DoNothing"
    }
}
