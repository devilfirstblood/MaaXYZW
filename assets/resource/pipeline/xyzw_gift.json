{
    // 咸鱼之王 —— 每日任务「赠送好友3次金币」
    // 流程：每日任务页 -> 点"赠送好友3次金币"行的"前往" -> 好友页 -> 点"一键领取和赠送" -> 关奖励弹窗
    // 坐标/ROI 基于 720 缩放系，box 来自实测 OCR。
    //
    // 前置：游戏需在每日任务页（可先跑 每日任务_打开 进入）。
    // 入口节点 复用 每日任务_打开 的话需先到任务页；这里入口直接从任务页确认开始。

    // 入口：确认在每日任务页（标题"每日任务"），命中后去点"赠送金币"的前往
    "赠送金币_入口": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            10,
            420,
            360,
            160
        ],
        "action": "DoNothing",
        "post_delay": 300,
        "next": [
            "赠送金币_点前往"
        ]
    },

    // 用"赠送好友...金币"文字定位任务行，target_offset 右移到该行的"前往"按钮再点。
    // 任务列表会动态重排，所以不能写死坐标——靠文字锚定行，右移点前往最稳。
    // 实测：文字 box≈[157,549,171,27]（中心x≈242），前往 box≈[559,556]（中心x≈588），
    // x 偏移≈+346；y 同行。target=true 取本节点识别 box，offset 只移 x。
    "赠送金币_点前往": {
        "recognition": "OCR",
        "expected": "赠送好友.*金币",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            346,
            0,
            0,
            0
        ],
        "post_delay": 2500,
        "next": [
            "赠送金币_一键赠送",
            "赠送金币_已完成跳过"
        ]
    },

    // 好友页：点底部"一键领取和赠送"（OCR box≈[254,1012,218,36]，中心[363,1030]）
    // 这是常驻按钮（点完不消失），只点一次。点完会弹"恭喜获得"奖励。
    "赠送金币_一键赠送": {
        "recognition": "OCR",
        "expected": "一键领取和赠送",
        "roi": [
            200,
            980,
            330,
            100
        ],
        "action": "Click",
        "post_delay": 2000,
        "next": [
            "赠送金币_关奖励弹窗"
        ]
    },

    // 关"恭喜获得"奖励弹窗：识别到"恭喜获得"或提示文字就点空白关掉
    // 弹窗底部提示"点击任意区域返回主界面"，点空白即可。
    "赠送金币_关奖励弹窗": {
        "recognition": "OCR",
        "expected": "恭喜获得|点击任意区域",
        "roi": [
            0,
            0,
            720,
            1280
        ],
        "action": "Click",
        "target": [
            360,
            200,
            1,
            1
        ],
        "post_delay": 1200,
        "next": [
            "赠送金币_返回任务列表"
        ]
    },

    // 点左下角返回箭头，回到每日任务列表页。720系约[48,1152]（物理[60,1440]）。
    // （好友页返回箭头可直接回任务列表。）
    "赠送金币_返回任务列表": {
        "action": "Click",
        "target": [
            48,
            1152,
            1,
            1
        ],
        "post_delay": 1800,
        "next": [
            "赠送金币_领取奖励"
        ]
    },

    // 在任务列表点本任务行的"领取"领奖：任务名锚定行 + offset 右移点"领取"（offset=346）。
    "赠送金币_领取奖励": {
        "recognition": "OCR",
        "expected": "赠送好友.*金币",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            346,
            0,
            0,
            0
        ],
        "post_delay": 1200,
        "next": [
            "赠送金币_完成"
        ]
    },

    // 若"赠送金币"任务已完成（行里是"领取"而非"前往"），点前往会失败 -> 走这里直接结束。
    // （兜底：当任务已 3/3 时，赠送金币_点前往 因匹配不到对应"前往"而落空，此节点 DirectHit 收尾）
    "赠送金币_已完成跳过": {
        "action": "DoNothing"
    },

    // 完成
    "赠送金币_完成": {
        "action": "DoNothing"
    }
}
