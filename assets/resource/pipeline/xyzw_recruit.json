{
    // 咸鱼之王 —— 每日任务「进行2次招募」
    // 流程：每日任务页 -> 点"进行2次招募"行的"前往" -> 咸将招募页 ->
    //       点"招募一次"(第1次) -> 弹结果点"再抽1次"(第2次) -> 弹结果点"确定" -> 完成
    // 坐标基于 720 缩放系，box 来自实测 OCR。
    // 前置：游戏在每日任务页。

    // 入口：确认在每日任务页，去点"招募"的前往
    "招募_入口": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            20,
            460,
            200,
            70
        ],
        "action": "DoNothing",
        "post_delay": 300,
        "next": [
            "招募_点前往"
        ]
    },

    // 用"进行...招募"文字定位任务行，target_offset 右移到该行"前往"按钮。
    // 实测：文字 box≈[157,665,127,28]（中心x≈220），前往 box≈[559,673]（中心x≈588），
    // x 偏移≈+368；y 同行。（与赠送金币同法，offset 经实测行定位验证可靠。）
    "招募_点前往": {
        "recognition": "OCR",
        "expected": "进行.*次招募",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            368,
            0,
            0,
            0
        ],
        "post_delay": 2500,
        "next": [
            "招募_点招募一次"
        ]
    },

    // 招募页：点"招募一次"（消耗1券）。box≈[107,1025,193,56]，中心[203,1053]。
    // 点完弹"恭喜获得"招募结果（带 确定/再抽1次）。
    "招募_点招募一次": {
        "recognition": "OCR",
        "expected": "招募一次",
        "roi": [
            80,
            1000,
            240,
            100
        ],
        "action": "Click",
        "post_delay": 2500,
        "next": [
            "招募_再抽1次"
        ]
    },

    // 第1次结果弹窗：点"再抽1次"完成第2次招募。box≈[455,1004,116,38]，中心[513,1023]。
    "招募_再抽1次": {
        "recognition": "OCR",
        "expected": "再抽1次",
        "roi": [
            420,
            980,
            200,
            90
        ],
        "action": "Click",
        "post_delay": 2500,
        "next": [
            "招募_点确定"
        ]
    },

    // 第2次结果弹窗：点"确定"关闭。box≈[173,1000,75,45]，中心[210,1022]。
    // （此时已招募2次，任务满足。点确定回招募页。）
    "招募_点确定": {
        "recognition": "OCR",
        "expected": "^确定$",
        "roi": [
            140,
            980,
            180,
            90
        ],
        "action": "Click",
        "post_delay": 1500,
        "next": [
            "招募_返回任务列表"
        ]
    },

    // 点确定后停在咸将招募页，点左下返回箭头回任务列表。720系约[48,1152]。
    "招募_返回任务列表": {
        "action": "Click",
        "target": [
            48,
            1152,
            1,
            1
        ],
        "post_delay": 1800,
        "next": [
            "招募_领取奖励"
        ]
    },

    // 在任务列表点本任务行的"领取"领奖：任务名锚定行 + offset 右移点"领取"（offset=368）。
    "招募_领取奖励": {
        "recognition": "OCR",
        "expected": "进行.*次招募",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            368,
            0,
            0,
            0
        ],
        "post_delay": 1200,
        "next": [
            "招募_完成"
        ]
    },

    // 完成
    "招募_完成": {
        "action": "DoNothing"
    }
}
