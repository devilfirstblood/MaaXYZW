{
    // 咸鱼之王 —— 每日任务「一键全完成 + 领奖」串联链
    // 把 启动进主界面 -> 逐个完成各每日活动任务 -> 统一领奖 串成一条 next 链路，
    // 作为 GUI 里的单个 task（入口 全日常_启动）。
    //
    // 设计要点：
    //  - 各活动任务 pipeline（赠送/招募/点金/宝箱/黑市/竞技场）的入口节点都假设「已在每日任务页」
    //    （OCR 识别标题"每日任务"），而启动游戏后停在「主界面」。两者需用「打开任务页」衔接。
    //  - 各活动任务完成时(xxx_完成)都停在每日任务列表页（最后一步是在列表点本任务行的"领取"）。
    //    但领取可能弹小奖励窗遮住标题，故每段之间插「复位到任务页」节点：先点空白关弹窗，
    //    再确认在任务页，不在就重新走 每日任务_打开。
    //  - 跨文件 next 引用：MaaFramework 把所有 pipeline JSON 合并为一个全局节点表，
    //    节点名唯一即可跨文件 next 引用（赠送金币_入口/招募_入口... 均在各自文件中定义）。
    //  - 各 xxx_完成 是 DoNothing 且无 next（单独跑时是终点）；本链不改它们，
    //    而是用「复位节点」直接 next 到下一段入口，绕过 xxx_完成 继续往下。
    //
    // 坐标基于 720 缩放系。前置：从游戏未启动/主界面均可（启动节点会拉起 App）。

    // ===== 启动进主界面（复用 demo 的关弹窗逻辑） =====
    "全日常_启动": {
        "action": "StartApp",
        "package": "com.hortor.games.xyzw",
        "post_delay": 15000,
        "timeout": 60000,
        "next": [
            "全日常_确认主界面",
            "全日常_点空白关弹窗"
        ]
    },
    // 识别底部常驻入口(俱乐部/客厅/战斗)判断已在主界面
    "全日常_确认主界面": {
        "recognition": "OCR",
        "expected": "俱乐部|客厅|^战斗$",
        "roi": [
            0,
            1020,
            720,
            260
        ],
        "action": "DoNothing",
        "post_delay": 2500,
        "timeout": 60000,
        "next": [
            "全日常_二次确认主界面",
            "全日常_点空白关弹窗"
        ]
    },
    "全日常_二次确认主界面": {
        "recognition": "OCR",
        "expected": "俱乐部|客厅|^战斗$",
        "roi": [
            0,
            1020,
            720,
            260
        ],
        "action": "DoNothing",
        "post_delay": 500,
        // 主界面稳定 -> 进任务页开始日常
        "next": [
            "全日常_开任务页"
        ]
    },
    "全日常_点空白关弹窗": {
        "action": "Click",
        "target": [
            360,
            64,
            1,
            1
        ],
        "post_delay": 1500,
        "timeout": 60000,
        "next": [
            "全日常_确认主界面",
            "全日常_点空白关弹窗"
        ]
    },

    // ===== 进每日任务页（复用 每日任务_打开 的步骤，但走自己的衔接，避免触发它的领奖收尾） =====
    // 直接 next 到 每日任务_打开 会在领完奖后停在 每日任务_完成(无 next)，
    // 故这里自定义"开任务页"步骤，确认在任务页后接第一段活动任务。
    // 点主界面左上任务图标弹出左侧菜单列。
    // next 同时挂 [点任务菜单, 开任务页自身]：若菜单项没识别到(菜单未弹出/点偏)就再点一次图标，
    // 构成"点图标→找菜单"重试循环，受 timeout 兜底。避免单次点击失败就断链。
    "全日常_开任务页": {
        "action": "Click",
        "target": [
            70,
            150,
            40,
            40
        ],
        "post_delay": 1800,
        "timeout": 30000,
        "next": [
            "全日常_点任务菜单",
            "全日常_确认任务页",
            "全日常_开任务页"
        ]
    },
    // 左侧菜单点"任务"项。OCR 放宽为含"任务"(此时未进任务页,菜单里仅"任务"项,不会误匹配"每日任务")。
    // roi 放宽覆盖整列菜单 y 380~720,应对菜单弹出高度浮动。命中后点它进任务页。
    "全日常_点任务菜单": {
        "recognition": "OCR",
        "expected": "任务",
        "roi": [
            30,
            380,
            170,
            340
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1800,
        "next": [
            "全日常_确认任务页"
        ]
    },
    "全日常_确认任务页": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            10,
            420,
            360,
            160
        ],
        "action": "DoNothing",
        "post_delay": 500,
        // 进任务页后开始第一段：赠送好友金币
        "next": [
            "赠送金币_入口"
        ]
    },

    // ===== 复位节点：每段活动任务完成后回到任务页，再接下一段 =====
    // 实测各任务收尾落点：招募/点金/宝箱/黑市 完成后停在干净任务页；
    // 赠送领奖后会弹"万能橙将碎片"自选窗——它在屏幕中部，点 [360,200] 正好点在弹窗内关不掉，
    // 必须点屏幕顶部纯空白 [360,90]（任何弹窗都在其下方）才能关。故复位统一点 [360,90] 两次。
    //
    // 容错设计（关键）：复位点完空白后，next 直接挂 [下一段入口, 复位N重开]。
    //   下一段入口本身是 OCR "每日任务"——已在任务页则它命中、继续；没在(弹窗没关净/页面残留)
    //   则它不命中，轮询落到"复位N重开"(点任务图标重进任务页)再接下一段。
    //   不用单独的"确认"识别节点——识别节点没命中时其 next 兜底不会触发(框架特性)，会断链。
    //
    // 复位1：赠送完成 -> 招募
    "全日常_复位1": {
        "action": "Click",
        "target": [
            360,
            90,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位1之二"
        ]
    },
    "全日常_复位1之二": {
        "action": "Click",
        "target": [
            360,
            90,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "招募_入口",
            "全日常_复位1重开"
        ]
    },
    "全日常_复位1重开": {
        "action": "Click",
        "target": [
            70,
            150,
            40,
            40
        ],
        "post_delay": 1200,
        "next": [
            "招募_入口"
        ]
    },

    // 复位2：招募完成 -> 点金
    "全日常_复位2": {
        "action": "Click",
        "target": [
            360,
            90,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位2之二"
        ]
    },
    "全日常_复位2之二": {
        "action": "Click",
        "target": [
            360,
            90,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "点金_入口",
            "全日常_复位2重开"
        ]
    },
    "全日常_复位2重开": {
        "action": "Click",
        "target": [
            70,
