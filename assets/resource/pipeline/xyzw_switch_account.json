{
    // 咸鱼之王 —— 多开机器人「切换账号」原子动作
    // 点主界面顶部一个切换位头像(112/111) -> 出现「多开机器人切换角色成功!」toast
    //   -> 切号后偶发连串促销/活动弹窗(超值礼包/大闹天宫/十殿试炼...) -> 点空白逐个关
    //   -> 确认回到新账号主界面。
    //
    // 设计要点：
    //  - 本 pipeline 只做「一次切号 + 关弹窗 + 回主界面」这一步动作，不判断切到了哪个号、
    //    是否轮换重复——那由调用方(scripts/daily_all.js)在跑完后 OCR 标题关卡数对比判定。
    //  - 入口 切号_点头像 的 target 坐标由调用方用 pipeline_override 传入：
    //      左切换位头像 ≈ [208,228,1,1]，右切换位头像 ≈ [505,228,1,1]（720 缩放系）。
    //  - 关弹窗逻辑与 全日常_点空白关弹窗 同款：点顶部空白(360,64) 逐个关，
    //    直到 OCR 底部常驻入口(俱乐部/客厅/战斗) 命中即认为回到主界面。
    //
    // 坐标基于 720 缩放系。前置：已在主界面、且顶部存在可切换的头像位。

    // 入口：点切换位头像（target 由调用方 override 传左/右坐标）。
    // 默认填左切换位，作为单独跑/不 override 时的兜底。
    "切号_点头像": {
        "action": "Click",
        "target": [
            208,
            228,
            1,
            1
        ],
        // 切号有读条/特效，留足时间让 toast 与后续弹窗陆续弹出再处理
        "post_delay": 3000,
        "next": [
            "切号_确认主界面",
            "切号_点空白关弹窗"
        ]
    },

    // 识别底部常驻入口(俱乐部/客厅/战斗)判断已在(新账号)主界面
    "切号_确认主界面": {
        "recognition": "OCR",
        "expected": "俱乐部|客厅|^战斗$",
        "roi": [
            0,
            1020,
            720,
            260
        ],
        "action": "DoNothing",
        "post_delay": 2000,
        "timeout": 60000,
        "next": [
            "切号_二次确认主界面",
            "切号_点空白关弹窗"
        ]
    },
    // 再确认一次，确保弹窗都关干净、画面稳定后才算切号完成
    "切号_二次确认主界面": {
        "recognition": "OCR",
        "expected": "俱乐部|客厅|^战斗$",
        "roi": [
            0,
            1020,
            720,
            260
        ],
        "action": "DoNothing",
        "post_delay": 500
        // 无 next：到此即切号 pipeline 终点(回到新账号主界面)。
    },

    // 点顶部空白关一个弹窗后回去确认主界面；没回到则继续关。受 timeout 兜底。
    "切号_点空白关弹窗": {
        "action": "Click",
        "target": [
            360,
            64,
            1,
            1
        ],
        "post_delay": 1500,
        "timeout": 60000,
        "next": [
            "切号_确认主界面",
            "切号_点空白关弹窗"
        ]
    }
}
