{
    // 咸鱼之王 —— 俱乐部：每日签到 + 挑战boss(仅打第1次)
    // 设计依据：docs/superpowers/specs/2026-07-02-jlb-signin-boss-design.md
    // 流程：主界面点"俱乐部" -> 俱乐部主页 -> 点团长名片开签到浮层 -> OCR签到 -> 关浮层
    //       -> 点当前BOSS开攻打浮层 -> 攻打(仅第1次) -> 跳过战斗 -> 结算页点确定(不点再次攻打)
    //       -> 关浮层 -> 点返回箭头回主界面
    // 坐标基于 720 缩放系，来自 adb 截图实测（900x1600 物理，等比即 720 系），
    // 写节点后须真机跑 look.js 之类的脚本核实精确 box 再修正。
    // 前置：游戏在主界面（底部"战斗"Tab）；账号已加入某俱乐部。
    // ===== 入口：主界面点左下"俱乐部" =====
    "俱乐部_启动": {
        "recognition": "OCR",
        "expected": "俱乐部",
        "roi": [
            0,
            1020,
            200,
            260
        ],
        "action": "Click",
        "target": true,
        "post_delay": 2500,
        "next": [
            "俱乐部_确认主页",
            "俱乐部_启动"
        ]
    },
    // 确认已进俱乐部主页：识别顶部标题牌"俱乐部"文字。识别超时(如未加入俱乐部弹的是搜索页，
    // 8s 内一直识别不到)则不重试、直接放弃走兜底("俱乐部_未加入放弃")，避免在陌生页面乱点。
    // 注意：兜底走 on_error(超时/失败专用)而非 next——next 只在本节点识别命中后才会被遍历，
    // 若把兜底塞进 next 会被其后 俱乐部_开签到(DirectHit，无 recognition，必命中)抢先命中，
    // 导致"未加入俱乐部"分支永远走不到。
    "俱乐部_确认主页": {
        "recognition": "OCR",
        "expected": "俱乐部",
        "roi": [
            200,
            30,
            320,
            140
        ],
        "action": "DoNothing",
        "post_delay": 1500,
        "timeout": 3500,
        "next": [
            "俱乐部_开签到"
        ],
        "on_error": [
            "俱乐部_未加入放弃"
        ]
    },
    // 异常兜底：未在俱乐部主页(大概率未加入俱乐部)，不做任何处理直接结束。
    "俱乐部_未加入放弃": {
        "action": "DoNothing"
    },
    // ===== 分支1：签到 =====
    // 点左下角团长名片区域，弹出"详情"浮层。720系约[232,1064]（物理[290,1330]）。
    "俱乐部_开签到": {
        "action": "Click",
        "target": [
            232,
            1064,
            1,
            1
        ],
        "post_delay": 2000,
        "next": [
            "俱乐部_点签到",
            "俱乐部_关签到浮层"
        ]
    },
    // 详情浮层左上角"每日签到"按钮(绿色可点态)。OCR 命中则点击；已签到(灰色"已签到")
    // 或识别不到则 next 落到关浮层，不重试(避免详情浮层没弹出时死循环点名片)。
    "俱乐部_点签到": {
        "recognition": "OCR",
        "expected": "每日签到",
        "action": "Click",
        "target": true,
        "post_delay": 1500,
        "next": [
            "俱乐部_关签到浮层"
        ]
    },
    // 关闭详情浮层：点浮层顶部空白区域(暗色遮罩区)。720系约[360,80]。
    "俱乐部_关签到浮层": {
        "action": "Click",
        "target": [
            360,
            80,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "俱乐部_开boss"
        ]
    },
    // ===== 分支2：挑战 BOSS（每天仅打第1次） =====
    // 点俱乐部主页中间的"当前BOSS"角色模型，弹出攻打浮层("咸神试炼"+boss名)。
    // 720系约[360,704]（物理[450,880]）。
    "俱乐部_开boss": {
        "action": "Click",
        "target": [
            360,
            704,
            1,
            1
        ],
        "post_delay": 2000,
        "next": [
            "俱乐部_点攻打",
            "俱乐部_关boss浮层"
        ]
    },
    // 攻打浮层底部"攻打"按钮。OCR 精确匹配"^攻打$"避免误配"再次攻打"；
    // roi 限定底部按钮区，避开顶部"奖励预览"等其它按钮。
    // 识别不到(今日4次已用完、按钮置灰) -> next 落到关浮层，不重试、不等倒计时。
    "俱乐部_点攻打": {
        "recognition": "OCR",
        "expected": "^攻打$",
        "action": "Click",
        "target": true,
        "post_delay": 3000,
        "next": [
            "俱乐部_战斗中",
            "俱乐部_关boss浮层"
        ]
    },
    // 进入战斗页("俱乐部BOSS"标题)，点左下角"跳过"按钮快进。
    // 720系约[84,1076]（物理[105,1345]）。DirectHit：战斗页无需识别，点完等结算页出现。
    "俱乐部_战斗中": {
        "action": "Click",
        "target": [
            84,
            1076,
            1,
            1
        ],
        "post_delay": 2500,
        "next": [
            "俱乐部_确认结算"
        ]
    },
    // 确认到结算页："挑战成功"标题。若未命中(战斗还没结束/跳过没生效)，
    // 在 timeout 内重试等待；超时则直接走关浮层兜底，不卡死整条链。
    "俱乐部_确认结算": {
        "recognition": "OCR",
        "expected": "挑战成功",
        "roi": [
            150,
            150,
            420,
            180
        ],
        "action": "DoNothing",
        "post_delay": 500,
        "timeout": 15000,
        "next": [
            "俱乐部_点确定",
            "俱乐部_关boss浮层"
        ]
    },
    // 结算页左边"确定"按钮：每天只打第1次，不管右边"再次攻打(N/4)"显示什么次数，
    // 一律点确定退出，不点"再次攻打"。OCR 精确匹配"^确定$"避免误配其它按钮。
    "俱乐部_点确定": {
        "recognition": "OCR",
        "expected": "^确定$",
        "roi": [
            140,
            1170,
            250,
            120
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1500,
        "next": [
            "俱乐部_关boss浮层"
        ]
    },
    // 关闭攻打浮层：点浮层顶部空白区域(暗色遮罩区)。720系约[360,80]。
    // DirectHit 无条件点一次即可（若浮层已经因为"点确定"提前关闭，点空白落在俱乐部主页
    // 也无副作用，游戏内点主页空白区不会误触其它功能）。
    "俱乐部_关boss浮层": {
        "action": "Click",
        "target": [
            360,
            80,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "俱乐部_返回主界面"
        ]
    },
    // ===== 收尾：俱乐部 -> 主界面 =====
    // 俱乐部页右下角"客厅"按钮同排的返回箭头。720系约[640,1156]（物理[800,1445]）。
    "俱乐部_返回主界面": {
        "action": "Click",
        "target": [
            640,
            1156,
            1,
            1
        ],
        "post_delay": 1800,
        "next": [
            "俱乐部_完成"
        ]
    },
    "俱乐部_完成": {
        "action": "DoNothing"
    }
}