{
    // 咸鱼之王 —— 微信登录（检测登录页 -> 点"微信登录" -> 拉起微信授权页）
    //
    // 用途：启动游戏后若停在登录页(掉登录态)，点"微信登录"拉起微信授权/扫码，
    //       之后由调度脚本(scripts/account_login.js)截图发企微群提醒人工登录，并 1 分钟后切回。
    //
    // 设计：只负责"启动 -> 识别登录页 -> 点微信登录 -> 拉起微信"，截图/上报/切回等外部动作交给脚本。
    //   - 已登录(停在主界面/仍在加载)时 微信登录_点登录 识别不到"微信登录"->不命中->超时退出，
    //     脚本据 该节点 reco.hit 判断到底有没有进登录流程，决定要不要走截图上报。
    //   - 坐标基于 720 缩放系。"微信登录"按钮实测 OCR box [321,582,110,34]，target:true 点其中心。
    //
    // 实测两条真实路径（点"微信登录"行为取决于协议是否已勾选），pipeline 用 next 分支兼容：
    //   A. 协议未勾选(首次)：点登录 -> 弹"同意协议"窗 -> 点同意(仅勾选+关窗,回登录页) -> 再点登录 -> 拉起微信
    //   B. 协议已勾选：     点登录 -> 直接拉起微信(无同意窗)
    // 统一以"检测到微信授权页(登录微信/同意并登录)"为成功终点。
    // 入口：StartApp 拉起咸鱼之王(复用 咸鱼_启动游戏 的参数)，等开屏/loading 后找登录页。
    "微信登录_启动": {
        "action": "StartApp",
        "package": "com.hortor.games.xyzw",
        "post_delay": 8000,
        "timeout": 20000,
        "next": [
            "微信登录_点登录"
        ]
    },
    // 识别登录页的"微信登录"绿色按钮并点击(第一次)。
    // expected 用精确"微信登录"(不是宽泛"登录")，避免匹配到"其他登录方式"/"登录注册即表示同意"协议文字。
    // roi 收在白卡片按钮区(y 540~640)，排除底部协议行。timeout 放宽 30s：冷启动 loading 慢，登录页晚出。
    // 命中点击 -> 进 next 分支：先看是否已直接拉起微信(B路径)，没有再找同意窗(A路径)。
    // 始终未命中(已登录) -> 超时退出，脚本据本节点 hit 不做上报。
    "微信登录_点登录": {
        "recognition": "OCR",
        "expected": "微信登录",
        "roi": [
            150,
            540,
            420,
            100
        ],
        "action": "Click",
        "target": true,
        "post_delay": 2000,
        "timeout": 10000,
        "next": [
            "微信登录_确认已拉起微信",
            "微信登录_点同意协议"
        ]
    },
    // A 路径：点登录后弹"根据平台相关协议规定,需同意《隐私条款》以及《用户协议》"确认窗。
    // 点蓝色"同意"按钮(实测 box [435,673,52,32]，中心约 [461,689])。
    // 注意：点"同意"只勾选协议+关弹窗、回登录页，不会自动拉起微信 -> 接 再点登录。
    // expected "^同意$" 精确(排除"不同意"，且其在 x<360 不进本 roi)；target:true 点中心。
    "微信登录_点同意协议": {
        "recognition": "OCR",
        "expected": "^同意$",
        "roi": [
            360,
            640,
            240,
            90
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1500,
        "timeout": 15000,
        "next": [
            "微信登录_再点登录"
        ]
    },
    // A 路径续：协议已勾选，再点一次"微信登录"才真正拉起微信。点完接"确认已拉起微信"成功终点。
    "微信登录_再点登录": {
        "recognition": "OCR",
        "expected": "微信登录",
        "roi": [
            150,
            540,
            420,
            100
        ],
        "action": "Click",
        "target": true,
        "post_delay": 2000,
        "timeout": 15000,
        "next": [
            "微信登录_确认已拉起微信"
        ]
    },
    // 成功终点(A/B 两路径共用)：检测到微信授权/登录页特征文字即算拉起成功。
    // 微信"登录微信"页有标题"登录微信"和底部"同意并登录"按钮；扫码授权页也含"登录"字样。
    // DoNothing 不操作，命中即任务成功(status=3000)。拉起微信后由脚本等几秒截图发企微。
    // timeout 放宽：点登录到微信 App 拉起/页面渲染可能要几秒。
    "微信登录_确认已拉起微信": {
        "recognition": "OCR",
        "expected": "登录微信|同意并登录|授权",
        "roi": [
            0,
            0,
            720,
            1280
        ],
        "action": "DoNothing",
        "post_delay": 500,
        "timeout": 15000
    }
}