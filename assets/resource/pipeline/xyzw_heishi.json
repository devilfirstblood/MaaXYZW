{
    // 咸鱼之王 —— 每日任务「黑市购买1次物品」
    // 流程：每日任务页 -> 点"黑市购买1次物品"行的"前往" -> 黑市页 ->
    //       点底部"采购"(按采购清单一键购买) -> 弹"采购完成/恭喜获得" -> 点空白关 -> 完成
    // 坐标基于 720 缩放系，box 来自实测 OCR。前置：游戏在每日任务页。

    // 入口：确认在每日任务页，去点"黑市"的前往
    "黑市_入口": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            10,
            420,
            360,
            160
        ],
        "action": "DoNothing",
        "post_delay": 300,
        "timeout": 4000,
        // 第二条兜底：今日该任务已完成、行不在可视列表时，"点前往"OCR 不命中，
        // 当轮落到"黑市_完成"(DoNothing)立即跳过，串联跑不卡。
        "next": [
            "黑市_点前往",
            "黑市_完成"
        ]
    },

    // 用"黑市购买...物品"文字定位任务行，target_offset 右移到该行"前往"。
    // 实测：文字 box≈[158,781,171,28]（中心x≈243），前往中心x≈588，x 偏移≈+345。
    // roi 覆盖整个任务列表区，应对列表重排。
    "黑市_点前往": {
        "recognition": "OCR",
        "expected": "黑市购买.*物品",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            345,
            0,
            0,
            0
        ],
        "post_delay": 2500,
        // 已完成时点到"已领"章无效、进不了黑市页，"点采购"识别不到 ->
        // 5s 内轮询落到"黑市_完成"跳过，串联跑不卡。
        "timeout": 5000,
        "next": [
            "黑市_点采购",
            "黑市_完成"
        ]
    },

    // 黑市页底部"采购"按钮 box≈[311,1197,54,32]，中心[338,1213]。
    // 按采购清单一键购买；点完需等约5s（采购动画+弹"采购完成"->"恭喜获得"奖励）。
    "黑市_点采购": {
        "recognition": "OCR",
        "expected": "^采购$",
        "roi": [
            280,
            1175,
            120,
            80
        ],
        "action": "Click",
        "post_delay": 5000,
        "next": [
            "黑市_关奖励弹窗"
        ]
    },

    // 关"采购完成/恭喜获得"奖励弹窗：识别提示文字就点空白关掉。
    "黑市_关奖励弹窗": {
        "recognition": "OCR",
        "expected": "恭喜获得|采购完成|点击任意区域",
        "roi": [
            0,
            0,
            720,
            1280
        ],
        "action": "Click",
        "target": [
            360,
            200,
            1,
            1
        ],
        "post_delay": 1200,
        "next": [
            "黑市_返回任务列表"
        ]
    },

    // 点左下角返回箭头，回到每日任务列表页。720系约[48,1152]（物理[60,1440]）。
    "黑市_返回任务列表": {
        "action": "Click",
        "target": [
            48,
            1152,
            1,
            1
        ],
        "post_delay": 1800,
        "next": [
            "黑市_领取奖励"
        ]
    },

    // 在任务列表点本任务行的"领取"领奖：用任务名锚定行 + 同 offset 右移点"领取"
    // （"领取"与"前往"同 x 位置，offset 一致=345）。点领取无弹窗、行即消失、即时到账。
    "黑市_领取奖励": {
        "recognition": "OCR",
        "expected": "黑市购买.*物品",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            345,
            0,
            0,
            0
        ],
        "post_delay": 1200,
        "next": [
            "黑市_完成"
        ]
    },

    // 完成
    "黑市_完成": {
        "action": "DoNothing"
    }
}
