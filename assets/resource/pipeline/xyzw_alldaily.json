    // 复位4：宝箱完成 -> 黑市
    "全日常_复位4": {
        "action": "Click",
        "target": [
            360,
            90,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位4之二"
        ]
    },
    "全日常_复位4之二": {
