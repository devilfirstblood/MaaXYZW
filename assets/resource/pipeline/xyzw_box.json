{
    // 咸鱼之王 —— 每日任务「开启3次宝箱」
    // 流程：每日任务页 -> 点"开启3次宝箱"行的"前往" -> 宝箱页 ->
    //       点"打开10个宝箱"(一次即满足3次) -> 弹"恭喜获得" -> 点"确定" -> 完成
    // 坐标基于 720 缩放系，box 来自实测 OCR。前置：游戏在每日任务页。
    // 注：任务"次数"按开箱数量算，打开10个即 ≥3 次，故只需点一次"打开10个宝箱"。

    // 入口：确认在每日任务页，去点"宝箱"的前往
    "宝箱_入口": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            10,
            420,
            360,
            160
        ],
        "action": "DoNothing",
        "post_delay": 300,
        "timeout": 4000,
        // 第二条兜底：今日该任务已完成、行不在可视列表时，"点前往"OCR 不命中，
        // 当轮落到"宝箱_完成"(DoNothing)立即跳过，串联跑不卡。
        "next": [
            "宝箱_点前往",
            "宝箱_完成"
        ]
    },

    // 用"开启...宝箱"文字定位任务行，target_offset 右移到该行"前往"。
    // 实测：文字 box≈[156,1017,129,28]（中心x≈220），前往中心x≈588，x 偏移≈+368。
    // roi 覆盖整个任务列表区，应对列表重排（完成任务会上移）。
    "宝箱_点前往": {
        "recognition": "OCR",
        "expected": "开启.*次宝箱",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            368,
            0,
            0,
            0
        ],
        "post_delay": 2500,
        // 已完成时点到"已领"章无效、进不了活动页，下一活动节点识别不到 ->
        // 5s 内轮询落到"_完成"跳过，串联跑不卡。
        "timeout": 5000,
        "next": [
            "宝箱_打开10个",
            "宝箱_完成"
        ]
    },

    // 宝箱页：点"打开10个宝箱" box≈[258,825,194,40]，中心[355,845]。
    // 点完弹"恭喜获得"结果（带 确定/再抽10次）。
    "宝箱_打开10个": {
        "recognition": "OCR",
        "expected": "打开.*个宝箱",
        "roi": [
            230,
            800,
            250,
            90
        ],
        "action": "Click",
        "post_delay": 2500,
        "next": [
            "宝箱_点确定"
        ]
    },

    // 结果弹窗：点"确定"关闭 box≈[160,825,72,41]，中心[196,845]。
    "宝箱_点确定": {
        "recognition": "OCR",
        "expected": "^确定$",
        "roi": [
            130,
            800,
            150,
            90
        ],
        "action": "Click",
        "post_delay": 1500,
        "next": [
            "宝箱_返回1"
        ]
    },

    // 宝箱收尾：宝箱页返回箭头会先到"咸将页"、再到主界面（不直接回任务列表），
    // 所以固定点 2 次返回箭头回主界面，再重新打开任务列表。
    // 返回箭头 720系约[48,1152]（物理[60,1440]）。
    "宝箱_返回1": {
        "action": "Click",
        "target": [
            48,
            1152,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "宝箱_返回2"
        ]
    },
    "宝箱_返回2": {
        "action": "Click",
        "target": [
            48,
            1152,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "宝箱_点任务图标"
        ]
    },

    // 回到主界面后，点左上任务图标弹左侧菜单。任务图标 720系约[70,150]。
    // next 挂 [点任务菜单, 点任务图标自身]：菜单没识别到就再点一次图标，构成重试循环
    // （与 全日常_开任务页 同思路），避免单次点击失败就断链。
    "宝箱_点任务图标": {
        "action": "Click",
        "target": [
            70,
            150,
            40,
            40
        ],
        "post_delay": 1800,
        "timeout": 20000,
        "next": [
            "宝箱_点任务菜单",
            "宝箱_点任务图标"
        ]
    },

    // 左侧菜单点"任务"项。OCR 放宽为含"任务"+roi 放宽覆盖整列菜单（与 全日常_点任务菜单 一致，
    // 旧的 ^任务$ + 窄 roi 不稳，曾导致这里识别不到卡住）。命中后点它进任务列表。
    "宝箱_点任务菜单": {
        "recognition": "OCR",
        "expected": "任务",
        "roi": [
            30,
            380,
            170,
            340
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1800,
        "next": [
            "宝箱_领取奖励"
        ]
    },

    // 在任务列表点本任务行的"领取"领奖：任务名锚定行 + offset 右移点"领取"（offset=368）。
    "宝箱_领取奖励": {
        "recognition": "OCR",
        "expected": "开启.*次宝箱",
        "roi": [
            140,
            520,
            260,
            620
        ],
        "action": "Click",
        "target": true,
        "target_offset": [
            368,
            0,
            0,
            0
        ],
        "post_delay": 1200,
        "next": [
            "宝箱_完成"
        ]
    },

    // 完成
    "宝箱_完成": {
        "action": "DoNothing"
    }
}
