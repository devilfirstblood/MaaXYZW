        ],
        "post_delay": 1800,
        "next": [
            "点金_领取奖励"
        ]
    },

    // 在任务列表点本任务行的"领取"领奖：任务名锚定行 + offset 右移点"领取"（offset=367）。
    "点金_领取奖励": {
        "recognition": "OCR",
        "expected": "进行.*次点金",
        "roi": [
            140,
