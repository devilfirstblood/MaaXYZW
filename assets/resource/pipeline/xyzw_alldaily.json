{
    // 咸鱼之王 —— 每日任务「一键全完成 + 领奖」串联链
    // 把 启动进主界面 -> 逐个完成各每日活动任务 -> 统一领奖 串成一条 next 链路，
    // 作为 GUI 里的单个 task（入口 全日常_启动）。
    //
    // 设计要点：
    //  - 各活动任务 pipeline（赠送/招募/点金/宝箱/黑市/竞技场）的入口节点都假设「已在每日任务页」
    //    （OCR 识别标题"每日任务"），而启动游戏后停在「主界面」。两者需用「打开任务页」衔接。
    //  - 各活动任务完成时(xxx_完成)都停在每日任务列表页（最后一步是在列表点本任务行的"领取"）。
    //    但领取可能弹小奖励窗遮住标题，故每段之间插「复位到任务页」节点：点空白关弹窗两次，
    //    再交给下一段入口(OCR"每日任务",自带 timeout 重试窗口)确认在任务页。
    //  - 跨文件 next 引用：MaaFramework 把所有 pipeline JSON 合并为一个全局节点表，
    //    节点名唯一即可跨文件 next 引用（赠送金币_入口/招募_入口... 均在各自文件中定义）。
    //  - 各 xxx_完成 是 DoNothing 且无 next（单独跑时是终点）；本链不改它们，
    //    而是用「复位节点」直接 next 到下一段入口，绕过 xxx_完成 继续往下。
    //
    // 坐标基于 720 缩放系。前置：从游戏未启动/主界面均可（启动节点会拉起 App）。

    // ===== 启动进主界面（复用 demo 的关弹窗逻辑） =====
    "全日常_启动": {
        "action": "StartApp",
        "package": "com.hortor.games.xyzw",
        "post_delay": 15000,
        "timeout": 60000,
        "next": [
            "全日常_确认主界面",
            "全日常_点空白关弹窗"
        ]
    },
    // 识别底部常驻入口(俱乐部/客厅/战斗)判断已在主界面
    "全日常_确认主界面": {
        "recognition": "OCR",
        "expected": "俱乐部|客厅|^战斗$",
        "roi": [
            0,
            1020,
            720,
            260
        ],
        "action": "DoNothing",
        "post_delay": 2500,
        "timeout": 60000,
        "next": [
            "全日常_二次确认主界面",
            "全日常_点空白关弹窗"
        ]
    },
    "全日常_二次确认主界面": {
        "recognition": "OCR",
        "expected": "俱乐部|客厅|^战斗$",
        "roi": [
            0,
            1020,
            720,
            260
        ],
        "action": "DoNothing",
        "post_delay": 500,
        // 主界面稳定 -> 进任务页开始日常
        "next": [
            "全日常_开任务页"
        ]
    },
    "全日常_点空白关弹窗": {
        "action": "Click",
        "target": [
            360,
            64,
            1,
            1
        ],
        "post_delay": 1500,
        "timeout": 60000,
        "next": [
            "全日常_确认主界面",
            "全日常_点空白关弹窗"
        ]
    },

    // ===== 进每日任务页（统一入口，串联链和独立领奖 task 都复用）=====
    // 独立「每日任务领奖」task 入口即此节点，用 override 把 全日常_确认任务页 的 next
    // 改到 每日任务_领任务奖；串联链则默认接第一段"赠送"。
    // 点主界面左上任务图标弹出左侧菜单列。
    // next 同时挂 [点任务菜单, 开任务页自身]：若菜单项没识别到(菜单未弹出/点偏)就再点一次图标，
    // 构成"点图标→找菜单"重试循环，受 timeout 兜底。避免单次点击失败就断链。
    "全日常_开任务页": {
        "action": "Click",
        "target": [
            70,
            150,
            40,
            40
        ],
        "post_delay": 1800,
        "timeout": 30000,
        "next": [
            "全日常_点任务菜单",
            "全日常_确认任务页",
            "全日常_开任务页"
        ]
    },
    // 左侧菜单点"任务"项。OCR 放宽为含"任务"(此时未进任务页,菜单里仅"任务"项,不会误匹配"每日任务")。
    // roi 放宽覆盖整列菜单 y 380~720,应对菜单弹出高度浮动。命中后点它进任务页。
    "全日常_点任务菜单": {
        "recognition": "OCR",
        "expected": "任务",
        "roi": [
            30,
            380,
            170,
            340
        ],
        "action": "Click",
        "target": true,
        "post_delay": 1800,
        "next": [
            "全日常_确认任务页"
        ]
    },
    "全日常_确认任务页": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            10,
            420,
            360,
            160
        ],
        "action": "DoNothing",
        "post_delay": 500,
        // 进任务页后开始第一段：赠送好友金币
        "next": [
            "赠送金币_入口"
        ]
    },

    // ===== 复位节点：每段活动任务完成后回到任务页，再接下一段 =====
    // 实测各任务收尾落点：招募/点金/宝箱/黑市 完成后停在干净任务页；
    // 赠送领奖后会弹"万能橙将碎片"自选窗——它在屏幕中部，点 [360,200] 正好点在弹窗内关不掉，
    // 须点弹窗外上方空白才能关。但 [360,90] 会落在任务页顶部"任务/成就"标签栏上，
    // 没弹窗时点它会切到"成就"页导致下一段入口找不到"每日任务"。
    // 故用 [360,40]（标签栏之上的标题区，无可点功能，仍在所有弹窗外上方），复位统一点两次。
    //
    // 容错设计（关键）：复位点完两次空白后，next 直接接下一段入口。
    //   下一段入口本身是 OCR "每日任务" + timeout:4000——已在任务页则立即命中继续；
    //   弹窗刚关画面未稳的瞬间没命中，靠入口自己的 timeout 重试窗口等稳定后再命中。
    //   早期版本在此挂"点任务图标重开"兜底，但已在任务页时点图标反而会切到"成就"页/弹菜单
    //   破坏页面，故移除——复位只负责关弹窗，确认在任务页交给入口的 timeout 重试。
    //
    // 复位1：赠送完成 -> 招募
    "全日常_复位1": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位1之二"
        ]
    },
    "全日常_复位1之二": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "招募_入口"
        ]
    },

    // 复位2：招募完成 -> 点金
    "全日常_复位2": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位2之二"
        ]
    },
    "全日常_复位2之二": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "点金_入口"
        ]
    },

    // 复位3：点金完成 -> 宝箱
    "全日常_复位3": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位3之二"
        ]
    },
    "全日常_复位3之二": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "宝箱_入口"
        ]
    },

    // 复位4：宝箱完成 -> 黑市
    "全日常_复位4": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位4之二"
        ]
    },
    "全日常_复位4之二": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "黑市_入口"
        ]
    },

    // 复位5：黑市完成 -> 竞技场
    "全日常_复位5": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位5之二"
        ]
    },
    "全日常_复位5之二": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "竞技场_入口"
        ]
    },

    // 复位6：竞技场完成 -> 统一领奖（领周/日活跃宝箱）
    "全日常_复位6": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "全日常_复位6之二"
        ]
    },
    "全日常_复位6之二": {
        "action": "Click",
        "target": [
            360,
            40,
            1,
            1
        ],
        "post_delay": 1000,
        // 接"确认在任务页"(其 next 有 领任务奖+领周活跃 双出口)，而非直接接"领任务奖"——
        // 任务奖都领完时"领任务奖"识别不到"领取"会卡住，需经确认节点转去领周/日活跃。
        "next": [
            "每日任务_确认在任务页"
        ]
    },

    // =====================================================================
    // ===== 每日任务领奖段（原 xyzw_daily.json 整合进来）=====
    // 本段是串联链收尾"统一领奖"的目标，也是独立 task「咸鱼之王-每日任务领奖」的领奖逻辑。
    //
    // 进任务页统一复用上面的「全日常_开任务页」那套（带点图标→找菜单重试循环，且能容忍
    // 已在任务页：其 next 挂了 全日常_确认任务页，已在任务页时直接命中跳过点图标）。
    // 独立「每日任务领奖」task 入口即设为 全日常_开任务页，并用 pipeline_override 把
    // 全日常_确认任务页 的 next 改成 [每日任务_领任务奖]（默认它走串联第一段"赠送"）。
    //
    // 流程：进任务页 -> 循环领任务奖 -> 各领一次周/日活跃 -> 完成。
    // =====================================================================

    // 确认在任务页后进入领奖循环：标题在则反复尝试领取，直到领无可领。
    // （独立领奖 task 经 override 从 全日常_确认任务页 接到此处；串联链从 复位6 接 每日任务_领任务奖）
    "每日任务_确认在任务页": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            10,
            420,
            360,
            160
        ],
        "action": "DoNothing",
        "post_delay": 500,
        "next": [
            "每日任务_领任务奖",
            "每日任务_领周活跃"
        ]
    },

    // ===== 领奖：先循环领任务奖，再各领一次周/日活跃 =====

    // 1) 领单个任务奖励：在任务列表区(y 530~1130)找绿色"领取"按钮点击
    // 任务行"领取"box x≈561、y∈{556,673,...}；"前往"也在 x≈559 但文字是"前往"，OCR 精确区分。
    // 点一个后列表刷新（该行消失/上移），回确认节点重新找，构成"领任务奖"循环。
    // 当任务行已无"领取"（全是"前往"或领完）-> 确认节点的 next 落到"领周活跃"，退出循环。
    "每日任务_领任务奖": {
        "recognition": "OCR",
        "expected": "^领取$",
        "roi": [
            540,
            530,
            120,
            600
        ],
        "action": "Click",
        "post_delay": 1500,
        "next": [
            "每日任务_确认在任务页"
        ]
    },

    // 2) 领周活跃宝箱："全部领取"是常驻按钮（领完不消失），不能循环，只点一次。
    // 周活跃那排"全部领取"按钮 720系中心约 [620,227]（OCR: 全部[594,213]+领取[595,240]）。
    // DirectHit 直接按坐标点；点完线性走到日活跃，不回确认页（避免重复点）。
    // 若已领完，点击会弹"没有可领取的奖励"提示并自动消失，无副作用。
    "每日任务_领周活跃": {
        "action": "Click",
        "target": [
            595,
            213,
            55,
            36
        ],
        "post_delay": 1500,
        "next": [
            "每日任务_关周活跃提示",
            "每日任务_领日活跃"
        ]
    },

    // 周活跃点"全部领取"后：领到奖励会弹"恭喜获得"大弹窗(遮住日活跃按钮)，无奖励则弹
    // "没有可领取"提示。两种都要关，否则恭喜获得弹窗会挡住日活跃的"全部领取"导致日活跃没领。
    // 故无条件点空白两次(DirectHit)关掉任何弹窗，再去领日活跃。
    "每日任务_关周活跃提示": {
        "action": "Click",
        "target": [
            360,
            300,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "每日任务_关周活跃提示2"
        ]
    },
    "每日任务_关周活跃提示2": {
        "action": "Click",
        "target": [
            360,
            300,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "每日任务_领日活跃"
        ]
    },

    // 3) 领日活跃宝箱：日活跃那排"全部领取"按钮 720系中心约 [620,377]（OCR: 领取[595,389]）。
    "每日任务_领日活跃": {
        "action": "Click",
        "target": [
            595,
            364,
            55,
            36
        ],
        "post_delay": 1500,
        "next": [
            "每日任务_关日活跃提示",
            "每日任务_完成"
        ]
    },

    // 日活跃点"全部领取"后同样：领到弹"恭喜获得"、无奖励弹"没有可领取"，
    // 无条件点空白两次关掉任何弹窗，再走到完成(收尾干净不留弹窗)。
    "每日任务_关日活跃提示": {
        "action": "Click",
        "target": [
            360,
            300,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "每日任务_关日活跃提示2"
        ]
    },
    "每日任务_关日活跃提示2": {
        "action": "Click",
        "target": [
            360,
            300,
            1,
            1
        ],
        "post_delay": 1000,
        "next": [
            "每日任务_完成"
        ]
    },

    // 领奖结束（任务奖循环 + 周/日活跃各一次后到达）
    "每日任务_完成": {
        "action": "DoNothing"
    }
}
