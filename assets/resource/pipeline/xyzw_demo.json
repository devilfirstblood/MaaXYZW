{
    // 咸鱼之王示例 pipeline —— 启动游戏 + 连环关弹窗，直到稳定进入主界面
    // 坐标/ROI 基于 interface.json display_short_side: 720 缩放后尺寸（模拟器 900x1600 -> 720x1280）
    // 字段文档：https://maafw.com/docs/3.1-PipelineProtocol
    //
    // 循环原理：MaaFramework 对节点的 next 列表会自动循环识别（while(!timeout) foreach(next)）
    //
    // 难点：咸鱼之王弹窗是"陆续弹出"的——关掉充值弹窗会露出主界面一瞬，随后龙舟弹窗才弹出。
    // 若只要识别到一次"战斗"就结束，会在这一瞬误判完成。
    // 解决：
    //   1. "战斗"精确匹配(^战斗$)，排除背景"战斗中"误判
    //   2. 关弹窗节点先做，确认主界面节点要求画面静止(pre_wait_freezes)后才算数

    // 入口：StartApp 启动咸鱼之王，等 post_delay 后遍历一次 next：
    //   - 先试"确认主界面"(OCR 精确找底部"战斗")，有识别条件，没到主界面时不命中
    //   - 没命中才轮到"点空白关弹窗"(DirectHit 必命中) -> 关掉一个弹窗
    // (DirectHit 节点必须放最后做兜底，否则会每轮都命中、永远轮不到前面的判断)
    //
    // 注意：StartApp 是动作节点，执行一次后不会重入，它的 next 只遍历一轮、不构成循环。
    // 真正的"循环关连环弹窗"由后面 [确认主界面 <-> 点空白关弹窗] 两节点互相 next 构成，
    // 受各自 timeout 兜底。（早期版本误把循环寄托在本入口节点上，导致冷启动只点一次空白
    // 就结束、弹窗关不掉——已实跑复现并修复。）
    "咸鱼_启动游戏": {
        "action": "StartApp",
        "package": "com.hortor.games.xyzw",
        "post_delay": 15000,
        "timeout": 60000,
        "next": [
            "咸鱼_确认主界面",
            "咸鱼_点空白关弹窗"
        ]
    },

    // 第一次识别到主界面：OCR 识别底部常驻入口。
    // 原只认中间"^战斗$"，但战斗动画特效有时遮挡导致识别不到 -> 已在主界面却一直点空白不退出。
    // 改为认底部三个常驻入口之一(俱乐部/客厅/战斗，弹窗时都被遮挡)，任一命中即在主界面，更稳。
    // "客厅""俱乐部"在底部两角，比中间"战斗"更不易被战斗动画干扰。
    // 命中后不立刻结束——因为弹窗可能在"露出主界面一瞬"之后才陆续弹出，跳二次确认再判一次。
    "咸鱼_确认主界面": {
        "recognition": "OCR",
        "expected": "俱乐部|客厅|^战斗$",
        "roi": [
            0,
            1020,
            720,
            260
        ],
        "action": "DoNothing",
        "post_delay": 2500,
        // timeout 控制本节点 next 循环的总时长（while(!timeout) foreach(next)）。
        // 冷启动开屏+登录+loading+连环弹窗较慢，默认 20s 不够，放宽到 60s。
        "timeout": 60000,
        "next": [
            "咸鱼_二次确认主界面",
            "咸鱼_点空白关弹窗"
        ]
    },

    // 二次确认：等待后若底部入口仍在 -> 确实稳定在主界面，结束（无 next）
    // 若这 2.5s 内又弹出了新弹窗（识别不到入口）-> 回到上层循环的"点空白"继续关
    // 识别条件与"确认主界面"一致放宽（俱乐部/客厅/战斗任一）。
    "咸鱼_二次确认主界面": {
        "recognition": "OCR",
        "expected": "俱乐部|客厅|^战斗$",
        "roi": [
            0,
            1020,
            720,
            260
        ],
        "action": "DoNothing"
    },

    // 点屏幕最顶部空白遮罩区关闭弹窗（咸鱼之王弹窗均支持点弹窗外遮罩关闭）
    // 坐标落在所有弹窗图案上方的纯遮罩区(720系 y≈64)，太靠下会点到弹窗图案而关不掉
    // DirectHit 必命中；点完关掉一个弹窗后，next 回到"确认主界面"重新判断：
    //   - 已到主界面 -> 命中"确认主界面"走二次确认 -> 结束
    //   - 仍有弹窗   -> 再次命中本节点 -> 继续点空白关下一个（构成 确认主界面⇄点空白 的真循环）
    // 关键：本节点必须有 next 才能循环关连环弹窗；否则点一次就到链路终点、任务直接结束。
    // 循环由上层入口节点的 timeout 兜底（冷启动开屏+登录+loading+连环弹窗需较长时间）。
    "咸鱼_点空白关弹窗": {
        "action": "Click",
        "target": [
            360,
            64,
            1,
            1
        ],
        "post_delay": 1500,
        "timeout": 60000,
        "next": [
            "咸鱼_确认主界面",
            "咸鱼_点空白关弹窗"
        ]
    }
}
