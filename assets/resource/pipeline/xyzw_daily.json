{
    // 咸鱼之王 —— 每日任务：进任务页 -> 领任务奖 -> 领活跃度宝箱
    // 坐标/ROI 基于 interface.json display_short_side: 720 缩放系（模拟器 900x1600 -> 720x1280）
    // box 来自对每日任务页的实测 OCR（maa 截图同坐标系）
    //
    // 前置：游戏需在主界面（底部"战斗"Tab）。可先跑 xyzw_demo 的"咸鱼_启动游戏"进主界面。

    // ===== 入口：主界面 -> 点左上任务图标 -> 点"任务"菜单项 -> 进每日任务页 =====

    // 入口节点：点主界面左上的"任务/告示板"图标（卷轴+三横线+红感叹号）
    // 720系约 [88,168]（物理 900x1600 的 [110,210] 换算）。点完弹出左侧功能菜单列。
    "每日任务_打开": {
        "action": "Click",
        "target": [
            70,
            150,
            40,
            40
        ],
        "post_delay": 1200,
        "next": [
            "每日任务_点任务菜单"
        ]
    },

    // 左侧菜单列里点"任务"项（红色书本+红点，从上数第3项）
    // 720系约 [88,536]（物理 [110,670] 换算）。用 OCR 找"任务"二字更稳，限定左侧菜单区。
    "每日任务_点任务菜单": {
        "recognition": "OCR",
        "expected": "^任务$",
        "roi": [
            40,
            430,
            150,
            220
        ],
        "action": "Click",
        "post_delay": 1500,
        "next": [
            "每日任务_确认在任务页",
            "每日任务_点任务菜单兜底"
        ]
    },

    // 若 OCR 没找到"任务"二字（菜单还没弹出/位置偏），按换算坐标兜底点一次
    "每日任务_点任务菜单兜底": {
        "action": "Click",
        "target": [
            68,
            516,
            40,
            40
        ],
        "post_delay": 1500,
        "next": [
            "每日任务_确认在任务页"
        ]
    },

    // 确认已进每日任务页：识别标题"每日任务"（720系 box [33,477,135,33]）
    // 命中后进入领奖循环；标题在则反复尝试领取，直到领无可领
    "每日任务_确认在任务页": {
        "recognition": "OCR",
        "expected": "每日任务",
        "roi": [
            10,
            420,
            360,
            160
        ],
        "action": "DoNothing",
        "post_delay": 500,
        "next": [
            "每日任务_领任务奖",
            "每日任务_领周活跃"
        ]
    },

    // ===== 领奖：先循环领任务奖，再各领一次周/日活跃 =====

    // 1) 领单个任务奖励：在任务列表区(y 530~1130)找绿色"领取"按钮点击
    // 任务行"领取"box x≈561、y∈{556,673,...}；"前往"也在 x≈559 但文字是"前往"，OCR 精确区分。
    // 点一个后列表刷新（该行消失/上移），回确认节点重新找，构成"领任务奖"循环。
    // 当任务行已无"领取"（全是"前往"或领完）-> 确认节点的 next 落到"领周活跃"，退出循环。
    "每日任务_领任务奖": {
        "recognition": "OCR",
        "expected": "^领取$",
        "roi": [
            540,
            530,
            120,
            600
        ],
        "action": "Click",
        "post_delay": 1500,
        "next": [
            "每日任务_确认在任务页"
        ]
    },

    // 2) 领周活跃宝箱："全部领取"是常驻按钮（领完不消失），不能循环，只点一次。
    // 周活跃那排"全部领取"按钮 720系中心约 [620,227]（OCR: 全部[594,213]+领取[595,240]）。
    // DirectHit 直接按坐标点；点完线性走到日活跃，不回确认页（避免重复点）。
    // 若已领完，点击会弹"没有可领取的奖励"提示并自动消失，无副作用。
    "每日任务_领周活跃": {
        "action": "Click",
        "target": [
            595,
            213,
            55,
            36
        ],
        "post_delay": 1500,
        "next": [
            "每日任务_关周活跃提示",
            "每日任务_领日活跃"
        ]
    },

    // 周活跃点完若无奖励，弹"没有可领取的奖励"提示；点空白关掉，再续接到日活跃。
    // （若领到奖励则无此提示，本节点识别失败，由上层 next 直接走到"领日活跃"。）
    "每日任务_关周活跃提示": {
        "recognition": "OCR",
        "expected": "没有可领取",
        "roi": [
            180,
            560,
            360,
            120
        ],
        "action": "Click",
        "target": [
            360,
            300,
            1,
            1
        ],
        "post_delay": 800,
        "next": [
            "每日任务_领日活跃"
        ]
    },

    // 3) 领日活跃宝箱：日活跃那排"全部领取"按钮 720系中心约 [620,377]（OCR: 领取[595,389]）。
    "每日任务_领日活跃": {
        "action": "Click",
        "target": [
            595,
            364,
            55,
            36
        ],
        "post_delay": 1500,
        "next": [
            "每日任务_关日活跃提示",
            "每日任务_完成"
        ]
    },

    // 日活跃点完若无奖励，同样关掉提示，再走到完成。
    "每日任务_关日活跃提示": {
        "recognition": "OCR",
        "expected": "没有可领取",
        "roi": [
            180,
            560,
            360,
            120
        ],
        "action": "Click",
        "target": [
            360,
            300,
            1,
            1
        ],
        "post_delay": 800,
        "next": [
            "每日任务_完成"
        ]
    },

    // 领奖结束（任务奖循环 + 周/日活跃各一次后到达）
    "每日任务_完成": {
        "action": "DoNothing"
    }
}
