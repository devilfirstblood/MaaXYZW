{
    // 咸鱼之王 —— 盐罐加时
    // 原理：盐罐页右上角按钮（同一位置，靠颜色区分状态）：
    //   红色暂停"⏸" = 机器人运作中；绿色开始"▶" = 未启动。
    //   "加时"操作 = 若在运作(红)，先点暂停让它停 -> 按钮变绿 -> 再点开始重新启动，时间会增加。
    // 流程：主界面 -> 客厅 -> 点左侧三排数字进盐罐页 -> [若红则先点暂停] -> 点绿色开始 -> 返回客厅
    // 坐标基于 720 缩放系。按钮 720系约[506,352]（物理[632,440]），roi[462,310,90,90]。
    // 前置：游戏在主界面（底部"战斗"Tab）。

    // 入口：主界面点右下"客厅"
    "盐罐_入口": {
        "recognition": "OCR",
        "expected": "^客厅$",
        "roi": [
            580,
            1020,
            120,
            70
        ],
        "action": "Click",
        "post_delay": 2500,
        "next": [
            "盐罐_进盐罐页"
        ]
    },

    // 客厅页点左侧三排时间数字(盐罐入口)。OCR 找时间格式定位，点中间那排。
    // 实测三排数字 720系 y∈{576,649,724}、x≈105-195；点中间 [150,650]。
    "盐罐_进盐罐页": {
        "recognition": "OCR",
        "expected": "\\d\\d:\\d\\d:\\d\\d",
        "roi": [
            90,
            560,
            150,
            200
        ],
        "action": "Click",
        "post_delay": 2500,
        "next": [
            "盐罐_点暂停",
            "盐罐_点开始"
        ]
    },

    // 若按钮是红色暂停(机器人运作中)：先点一下暂停，让机器人停下、按钮变绿。
    // ColorMatch 检测 roi 内的鲜红像素；命中说明是暂停态。
    "盐罐_点暂停": {
        "recognition": "ColorMatch",
        "lower": [
            200,
            0,
            0
        ],
        "upper": [
            255,
            90,
            90
        ],
        "count": 800,
        "roi": [
            462,
            310,
            90,
            90
        ],
        "action": "Click",
        "target": [
            506,
            352,
            1,
            1
        ],
        "post_delay": 2000,
        "next": [
            "盐罐_点开始"
        ]
    },

    // 点绿色开始按钮启动机器人(加时)。ColorMatch 检测绿色；命中说明是开始态。
    // 若上一步刚点过暂停，此时按钮已变绿，这里点击启动。
    "盐罐_点开始": {
        "recognition": "ColorMatch",
        "lower": [
            0,
            150,
            0
        ],
        "upper": [
            160,
            255,
            120
        ],
        "count": 800,
        "roi": [
            462,
            310,
            90,
            90
        ],
        "action": "Click",
        "target": [
            506,
            352,
            1,
            1
        ],
        "post_delay": 2000,
        "next": [
            "盐罐_领取奖励"
        ]
    },

    // 加时后点底部"领取奖励"(一键领取全部罐子)。OCR box≈[277,1116,165,46]，中心[359,1139]。
    // 点完弹"恭喜获得"奖励。
    "盐罐_领取奖励": {
        "recognition": "OCR",
        "expected": "领取奖励",
        "roi": [
            250,
            1095,
            220,
            80
        ],
        "action": "Click",
        "post_delay": 2500,
        "next": [
            "盐罐_关奖励弹窗"
        ]
    },

    // 关奖励弹窗：点一下空白兜底。有"恭喜获得"弹窗就关掉；没奖励可领(罐子空)时无弹窗，
    // 点空白也无害。DirectHit 必命中，避免"无弹窗时识别不到而卡死"。然后回盐罐页。
    "盐罐_关奖励弹窗": {
        "action": "Click",
        "target": [
            360,
            200,
            1,
            1
        ],
        "post_delay": 1500,
        "next": [
            "盐罐_返回客厅"
        ]
    },

    // 盐罐页点左下返回箭头，回客厅。720系约[48,1152]。
    "盐罐_返回客厅": {
        "action": "Click",
        "target": [
            48,
            1152,
            1,
            1
        ],
        "post_delay": 1800,
        "next": [
            "盐罐_按返回键"
        ]
    },

    // 在客厅按安卓系统返回键，弹出"是否退出游戏?"确认框。
    "盐罐_按返回键": {
        "action": "ClickKey",
        "key": 4,
        "post_delay": 1500,
        "next": [
            "盐罐_确定退出"
        ]
    },

    // 点"确定"退出游戏。OCR box≈[464,749,76,45]，中心[502,771]。
    "盐罐_确定退出": {
        "recognition": "OCR",
        "expected": "^确定$",
        "roi": [
            440,
            730,
            130,
            80
        ],
        "action": "Click",
        "post_delay": 1500,
        "next": [
            "盐罐_完成"
        ]
    },

    // 完成（游戏已退出）
    "盐罐_完成": {
        "action": "DoNothing"
    }
}
